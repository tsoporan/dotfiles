{
  // SwayNC Configuration - Dracula Themed for Hyprland
  "$schema": "https://raw.githubusercontent.com/ErikReider/SwayNotificationCenter/main/src/configSchema.json",
  
  // Positioning and Display
  "positionX": "right",
  "positionY": "bottom", 
  "layer": "overlay",
  "layer-shell": true,
  "cssPriority": "application",
  "control-center-layer": "top",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-margin-left": 0,
  "control-center-width": 380,
  "control-center-height": 700,
  "control-center-exclusive-zone": false,
  
  // Notification Behavior
  "notification-2fa-action": true,
  "notification-inline-replies": false,
  "notification-icon-size": 64,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "notification-window-width": 380,
  "fit-to-screen": true,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "notification-visibility": {
    "state": "muted",
    "urgency": "Low",
    "app-name": "Spotify"
  },
  
  // Keyboard Shortcuts
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  
  // Widgets Configuration
  "widgets": [
    "title",
    "dnd",
    "notifications",
    "mpris",
    "volume",
    "menubar"
  ],
  
  // Widget-specific settings
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "label": {
      "max-lines": 5,
      "text": "Notification Center"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 8,
      "blur": true
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": false
    },
    "menubar": {
      "menu#power-options": {
        "label": "󰐥",
        "position": "right",
        "actions": [
          {
            "label": "󰌾 Lock",
            "command": "swaylock"
          },
          {
            "label": "󰍃 Logout", 
            "command": "hyprctl dispatch exit"
          },
          {
            "label": "󰜉 Reboot",
            "command": "systemctl reboot"
          },
          {
            "label": "󰐥 Shutdown",
            "command": "systemctl poweroff"
          }
        ]
      },
      "menu#screenshot": {
        "label": "󰄀",
        "position": "right", 
        "actions": [
          {
            "label": "󰩭 Area",
            "command": "grim -g \"$(slurp)\" - | wl-copy"
          },
          {
            "label": "󰍹 Full Screen",
            "command": "grim - | wl-copy"
          }
        ]
      }
    }
  },
  
  // Scripts and Commands
  "scripts": {
    "example-script": {
      "exec": "echo 'Hello World'",
      "urgency": "Normal"
    }
  }
}